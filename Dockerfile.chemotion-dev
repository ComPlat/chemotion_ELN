# This Dockerfile is used by docker-compose.dev.yml.
# It builds a development container with all dependencies required
# to run Chemotion ELN.
#
# Note: The initial build can take a while because several gems and
# native dependencies need to be compiled.

ARG source_image=ubuntu:24.04

FROM ${source_image} AS chemotion_dev_base

ARG DEBIAN_FRONTEND=noninteractive

RUN set -eux \
    && apt-get update --fix-missing \
    && apt-get upgrade -y \
    && apt-get install -yqq --fix-missing \
        # Base utilities
        apt-transport-https \
        bash \
        ca-certificates \
        curl \
        git \
        gpg \
        jq \
        nano \
        ranger \
        sudo \
        unzip \
        vim \
        wget \
        openssh-client \
        \
        # Build tools
        build-essential \
        cmake \
        swig \
        \
        # PostgreSQL
        postgresql-common \
        \
        # Development libraries
        libboost-all-dev \
        libmagic-dev \
        libmagickcore-dev \
        libmagickwand-dev \
        libpq-dev \
        libreadline-dev \
        libsqlite3-dev \
        libssl-dev \
        libyaml-dev \
        \
        # Runtime dependencies
        imagemagick \
        libgbm-dev \
        libgtk-3-0 \
        libgtk2.0-0 \
        libnotify-dev \
        libnspr4 \
        libnss3 \
        libxss1 \
        libxtst6 \
        gtk2-engines-pixbuf \
        p7zip-full \
        tzdata \
        xdg-utils \
        \
        # Fonts
        fonts-crosextra-caladea \
        fonts-crosextra-carlito \
        fonts-dejavu \
        fonts-dejavu-core \
        fonts-dejavu-extra \
        fonts-liberation \
        fonts-liberation2 \
        fonts-linuxlibertine \
        fonts-noto-core \
        fonts-noto-extra \
        fonts-noto-ui-core \
        fonts-opensymbol \
        fonts-sil-gentium \
        fonts-sil-gentium-basic \
        xfonts-100dpi \
        xfonts-75dpi \
        xfonts-base \
        xfonts-cyrillic \
        xfonts-scalable \
        \
        # Graphics / document rendering
        inkscape \
        \
        # X11 / headless browser support
        xauth \
        xvfb

# Install PostgreSQL client
RUN /usr/share/postgresql-common/pgdg/apt.postgresql.org.sh -y \
    && apt-get update \
    && apt-get install -yqq --fix-missing postgresql-client-16 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Allow passwordless sudo for the default Ubuntu user
RUN echo "ubuntu ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER ubuntu
WORKDIR /home/ubuntu

SHELL ["/bin/bash", "-c"]

# Configure ASDF paths globally so they are available when attaching
# to the container via `docker exec`, even before installation.
ENV ASDF_DIR=/home/ubuntu/.asdf
ENV PATH="${ASDF_DIR}/shims:${ASDF_DIR}/bin:${PATH}"

FROM chemotion_dev_base AS chemotion_eln_dev

ARG gid=default
ARG uid=default

USER root

COPY ./prepare-chuser.sh .
RUN ./prepare-chuser.sh "${uid}" "${gid}"

USER ubuntu

# Optional ASDF setup
# COPY --chown=ubuntu:ubuntu ./prepare-asdf.sh .
# COPY --chown=ubuntu:ubuntu ./.tool-versions .
# RUN chmod +x prepare-asdf.sh && ./prepare-asdf.sh